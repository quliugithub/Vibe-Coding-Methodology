{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/pack.schema.json",
  "title": "Pack",
  "type": "object",
  "required": [
    "pack_id",
    "spec_ref",
    "goal",
    "scope",
    "constraints",
    "verification_commands",
    "rollback_plan",
    "output_required"
  ],
  "properties": {
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "spec_ref": {
      "type": "string",
      "minLength": 1
    },
    "change_ref": {
      "type": "string"
    },
    "task_ref": {
      "type": "string"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "required": [
        "files"
      ],
      "properties": {
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "constraints": {
      "type": "object",
      "required": [
        "must",
        "must_not"
      ],
      "properties": {
        "must": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "must_not": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "ac": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "ui_facts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "tech_facts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "runtime_evidence": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "verification_commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "rollback_plan": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "output_required": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
